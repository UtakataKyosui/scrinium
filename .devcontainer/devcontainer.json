{
    "name": "scrinium",
    "build": {
        "dockerfile": "Dockerfile",
        "context": ".."
    },
    "remoteUser": "utakata",
    "customizations": {
        "vscode": {
            "extensions": [
                "bbenoist.Nix",
                "visualjj.visualjj",
                "Zerotaskx.rust-extension-pack",
                "rust-lang.rust-analyzer",
                "mkhl.direnv"
            ],
            "settings": {
                "terminal.integrated.inheritEnv": true,
                "rust-analyzer.server.path": "${containerWorkspaceFolder}/.direnv/bin/rust-analyzer"
            }
        }
    },
    "postCreateCommand": "cd ${containerWorkspaceFolder} && direnv allow",
    "postStartCommand": "bash -lc 'cd ${containerWorkspaceFolder} && eval \"$(direnv export bash)\" && mkdir -p .direnv/bin && ln -sf \"$(which rust-analyzer)\" .direnv/bin/rust-analyzer'"
}
