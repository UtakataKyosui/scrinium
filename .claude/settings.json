{
  "permissions": {
    "allow": [
      "WebFetch(domain:raw.githubusercontent.com)",
      "Bash(cargo build *)",
      "Bash(cargo run *)",
      "Bash(cargo add *)",
      "Bash(cargo test *)",
      "Bash(cargo check *)",
      "Bash(jj *)"
    ],
    "ask": [
      "Bash(jj git push *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR}/.claude/hooks/modern-cli.py",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
